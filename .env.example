POSTGRES_DB=morshid
POSTGRES_USER=morshid
POSTGRES_PASSWORD=morshid_local_password
POSTGRES_PORT=5432
REDIS_PORT=6379

# The app Compose profile injects PDF_STORAGE_PATH=/workspace/storage/pdfs and
# mounts the named PDF volume there. Host-run NestJS uses server/.env instead.

# Completion stays deterministic unless explicitly selected. The blank gateway
# key is intentional; place a newly rotated key only in an untracked .env file.
COMPLETION_PROVIDER=deterministic
COMPLETION_TIMEOUT_MS=30000
SBG_BASE_URL=https://apiaccess.iti.net.eg/api/v1
SBG_API_KEY=
SBG_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
SBG_MAX_TOKENS=1024

# Placeholder-only app-profile secrets. Replace both with different random
# values of at least 32 characters before using the Compose server runtime.
AUTH_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
AUTH_REFRESH_TOKEN_HASH_SECRET=replace-with-a-different-32-char-secret
