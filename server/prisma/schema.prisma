generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  DISABLED

  @@map("user_status")
}

enum CourseMembershipRole {
  INSTRUCTOR
  STUDENT

  @@map("course_membership_role")
}

enum MaterialStatus {
  PROCESSING
  READY
  WARNING
  FAILED

  @@map("material_status")
}

enum MessageRole {
  STUDENT
  ASSISTANT
  SYSTEM

  @@map("message_role")
}

enum MessageStatus {
  PENDING
  STREAMING
  COMPLETED
  FAILED
  BLOCKED

  @@map("message_status")
}

enum MessageRequestKind {
  CONCEPTUAL
  PROBLEM_LIKE
  ATTEMPT_DIAGNOSIS
  CODE_DIAGNOSIS
  UNSAFE
  OFF_TOPIC
  AMBIGUOUS

  @@map("message_request_kind")
}

enum MessageGuidanceLabel {
  COURSE_GROUNDED
  GENERAL_NOT_FOUND
  UNCERTAIN_AWAITING_REVIEW
  INSTRUCTOR_REVIEWED
  REFUSAL

  @@map("message_guidance_label")
}

model User {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String     @unique(map: "users_email_key") @db.Citext
  displayName       String     @map("display_name") @db.VarChar(120)
  role              UserRole
  status            UserStatus @default(ACTIVE)
  passwordHash      String     @map("password_hash") @db.Text
  disabledAt        DateTime?  @map("disabled_at") @db.Timestamptz(6)
  disabledById      String?    @map("disabled_by") @db.Uuid
  lastLoginAt       DateTime?  @map("last_login_at") @db.Timestamptz(6)
  passwordChangedAt DateTime   @default(now()) @map("password_changed_at") @db.Timestamptz(6)
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  disabledBy         User?              @relation("UserDisabledBy", fields: [disabledById], references: [id], onDelete: SetNull)
  disabledUsers      User[]             @relation("UserDisabledBy")
  refreshTokens      RefreshToken[]     @relation("UserRefreshTokens")
  createdCourses     Course[]           @relation("CourseCreatedBy")
  memberships        CourseMembership[] @relation("CourseMembershipUser")
  createdMemberships CourseMembership[] @relation("CourseMembershipCreatedBy")
  uploadedMaterials  Material[]         @relation("MaterialUploadedBy")
  chatSessions       ChatSession[]      @relation("ChatSessionStudent")
  messages           Message[]          @relation("MessageAuthor")
  auditLogs          AuditLog[]         @relation("AuditActor")

  @@index([disabledById], map: "idx_users_disabled_by")
  @@map("users")
}

model RefreshToken {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @unique(map: "refresh_tokens_token_hash_key") @map("token_hash") @db.Text
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  ip                String?   @db.Inet
  userAgent         String?   @map("user_agent") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user            User           @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)
  replacedByToken RefreshToken?  @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacedTokens  RefreshToken[] @relation("RefreshTokenReplacement")

  @@index([userId], map: "idx_refresh_tokens_user")
  @@index([replacedByTokenId], map: "idx_refresh_tokens_replaced_by")
  @@map("refresh_tokens")
}

model Course {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique(map: "courses_code_key") @db.VarChar(40)
  title       String   @db.VarChar(160)
  createdById String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy    User?              @relation("CourseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  memberships  CourseMembership[]
  materials    Material[]
  chatSessions ChatSession[]
  auditLogs    AuditLog[]

  @@index([createdById], map: "idx_courses_created_by")
  @@map("courses")
}

model CourseMembership {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String               @map("course_id") @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  role        CourseMembershipRole
  createdById String?              @map("created_by") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
  user         User          @relation("CourseMembershipUser", fields: [userId], references: [id], onDelete: Restrict)
  createdBy    User?         @relation("CourseMembershipCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  chatSessions ChatSession[] @relation("ChatSessionMembership")

  @@unique([courseId, userId], map: "course_memberships_course_id_user_id_key")
  @@index([courseId, role], map: "idx_memberships_course_role")
  @@index([userId], map: "idx_memberships_user")
  @@index([createdById], map: "idx_memberships_created_by")
  @@map("course_memberships")
}

model Material {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId            String         @map("course_id") @db.Uuid
  uploadedById        String         @map("uploaded_by") @db.Uuid
  title               String         @db.VarChar(180)
  originalFilename    String         @map("original_filename") @db.Text
  storagePath         String         @map("storage_path") @db.Text
  sha256Hash          String?        @map("sha256_hash") @db.Char(64)
  status              MaterialStatus @default(PROCESSING)
  extractedTextLength Int?           @map("extracted_text_length")
  chunkCount          Int?           @map("chunk_count")
  errorMessage        String?        @map("error_message") @db.Text
  deletedAt           DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  course     Course            @relation(fields: [courseId], references: [id], onDelete: Restrict)
  uploadedBy User              @relation("MaterialUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  chunks     MaterialChunk[]
  citations  MessageCitation[]

  @@index([courseId, status, deletedAt], map: "idx_materials_course_status")
  @@index([uploadedById], map: "idx_materials_uploaded_by")
  @@map("materials")
}

model MaterialChunk {
  id             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  materialId     String                      @map("material_id") @db.Uuid
  chunkIndex     Int                         @map("chunk_index")
  content        String                      @db.Text
  embedding      Unsupported("vector(1536)")
  embeddingModel String                      @map("embedding_model") @db.VarChar(120)
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  material   Material           @relation(fields: [materialId], references: [id], onDelete: Cascade)
  retrievals MessageRetrieval[]

  @@unique([materialId, chunkIndex], map: "material_chunks_material_id_chunk_index_key")
  @@index([materialId], map: "idx_chunks_material")
  @@map("material_chunks")
}

model ChatSession {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String    @map("course_id") @db.Uuid
  studentId     String    @map("student_id") @db.Uuid
  title         String    @db.VarChar(160)
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  course     Course           @relation(fields: [courseId], references: [id], onDelete: Restrict)
  student    User             @relation("ChatSessionStudent", fields: [studentId], references: [id], onDelete: Restrict)
  membership CourseMembership @relation("ChatSessionMembership", fields: [courseId, studentId], references: [courseId, userId], onDelete: Restrict)
  messages   Message[]

  @@index([courseId], map: "idx_sessions_course")
  @@index([courseId, studentId], map: "idx_sessions_course_student")
  @@index([studentId, courseId, deletedAt, lastMessageAt], map: "idx_sessions_student_course")
  @@map("chat_sessions")
}

model Message {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId           String                @map("session_id") @db.Uuid
  sequence            Int
  role                MessageRole
  authorUserId        String?               @map("author_user_id") @db.Uuid
  responseToMessageId String?               @map("response_to_message_id") @db.Uuid
  content             String                @db.Text
  status              MessageStatus
  requestKind         MessageRequestKind?   @map("request_kind")
  guidanceLabel       MessageGuidanceLabel? @map("guidance_label")
  hintLevel           Int?                  @map("hint_level") @db.SmallInt
  provider            String?               @db.VarChar(80)
  model               String?               @db.VarChar(120)
  promptVersion       String?               @map("prompt_version") @db.VarChar(80)
  inputTokens         Int?                  @map("input_tokens")
  outputTokens        Int?                  @map("output_tokens")
  errorCode           String?               @map("error_code") @db.VarChar(80)
  errorMessage        String?               @map("error_message") @db.Text
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt         DateTime?             @map("completed_at") @db.Timestamptz(6)

  session           ChatSession        @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  author            User?              @relation("MessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  responseToMessage Message?           @relation("MessageResponse", fields: [responseToMessageId], references: [id], onDelete: SetNull)
  responses         Message[]          @relation("MessageResponse")
  retrievals        MessageRetrieval[]
  citations         MessageCitation[]

  @@unique([sessionId, sequence], map: "messages_session_id_sequence_key")
  @@index([authorUserId], map: "idx_messages_author")
  @@index([responseToMessageId], map: "idx_messages_response_to")
  @@map("messages")
}

model MessageRetrieval {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId       String   @map("message_id") @db.Uuid
  chunkId         String?  @map("chunk_id") @db.Uuid
  rank            Int
  similarityScore Decimal? @map("similarity_score") @db.Decimal(8, 6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  message Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chunk   MaterialChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@unique([messageId, rank], map: "message_retrievals_message_id_rank_key")
  @@index([messageId], map: "idx_retrievals_message")
  @@index([chunkId], map: "idx_retrievals_chunk")
  @@map("message_retrievals")
}

model MessageCitation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId     String   @map("message_id") @db.Uuid
  materialId    String   @map("material_id") @db.Uuid
  citationOrder Int      @map("citation_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  message  Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@unique([messageId, citationOrder], map: "message_citations_message_id_citation_order_key")
  @@index([messageId], map: "idx_citations_message")
  @@index([materialId], map: "idx_citations_material")
  @@map("message_citations")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(100)
  targetType  String   @map("target_type") @db.VarChar(80)
  targetId    String?  @map("target_id") @db.Uuid
  courseId    String?  @map("course_id") @db.Uuid
  ip          String?  @db.Inet
  userAgent   String?  @map("user_agent") @db.Text
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor  User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  course Course? @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@index([courseId, createdAt], map: "idx_audit_course_created")
  @@index([actorUserId, createdAt], map: "idx_audit_actor_created")
  @@map("audit_logs")
}
