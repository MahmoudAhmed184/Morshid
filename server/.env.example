NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://morshid:morshid_local_password@localhost:5432/morshid
REDIS_URL=redis://localhost:6379

# Required host-run storage root. From the server workspace this resolves to
# the repository's git-ignored storage/pdfs directory.
PDF_STORAGE_PATH=../storage/pdfs

# Maximum accepted multipart PDF size in bytes. Default: 10485760 / 10 MiB.
PDF_MAX_UPLOAD_BYTES=10485760

# Embedding provider selection. `deterministic` is the only supported value in
# P0: it derives stable 1,536-dimension vectors locally and needs no API key
# or network access, so it is safe for CI, local work, and the backup demo.
EMBEDDING_PROVIDER=deterministic

# Course-scoped retrieval configuration. Both values are validated at startup
# and are never accepted from request, provider, or prompt input. TOP_K caps
# how many ranked chunks a retrieval returns (1-50); MIN_SIMILARITY (0-1) is
# the cosine-similarity floor below which retrieval reports insufficient
# evidence. Cosine similarity ranges [-1, 1], so a floor of 0 still excludes
# negatively correlated chunks — there is no "no threshold" setting. Change
# the 0.70 floor only after recording results against locked fixtures per the
# sprint 2 plan midpoint check.
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.7

# Auth/session configuration.
# Access JWTs are signed with HS256 using this secret. Use a unique random
# value with at least 32 characters per environment. The two secrets below must
# differ and must not keep the `replace-with` placeholder — the server refuses
# to boot otherwise.
AUTH_ACCESS_TOKEN_SECRET=replace-with-a-unique-32+-char-access-secret

# Refresh tokens are generated as opaque random values. The API stores only
# HMAC-SHA256(refreshToken, this secret), never the raw refresh token.
AUTH_REFRESH_TOKEN_HASH_SECRET=replace-with-a-different-32+-char-refresh-secret

# Access token lifetime in seconds. Default: 900 seconds / 15 minutes.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token lifetime in days. Default: 7 days.
AUTH_REFRESH_TOKEN_TTL_DAYS=7
