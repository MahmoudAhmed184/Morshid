NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://morshid:morshid_local_password@localhost:5432/morshid
REDIS_URL=redis://localhost:6379

# Required host-run storage root. From the server workspace this resolves to
# the repository's git-ignored storage/pdfs directory.
PDF_STORAGE_PATH=../storage/pdfs

# Auth/session configuration.
# Access JWTs are signed with HS256 using this secret. Use a unique random
# value with at least 32 characters per environment.
AUTH_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters

# Refresh tokens are generated as opaque random values. The API stores only
# HMAC-SHA256(refreshToken, this secret), never the raw refresh token.
AUTH_REFRESH_TOKEN_HASH_SECRET=replace-with-at-least-32-random-characters

# Access token lifetime in seconds. Default: 900 seconds / 15 minutes.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token lifetime in days. Default: 7 days.
AUTH_REFRESH_TOKEN_TTL_DAYS=7
