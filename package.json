{
  "name": "morshid",
  "private": true,
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=24.7 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "overrides": {
    "@nestjs/platform-express": {
      "multer": "2.2.0"
    },
    "@prisma/dev": {
      "@hono/node-server": "1.19.14"
    }
  },
  "scripts": {
    "dev": "concurrently --names client,server --prefix-colors cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run start:dev --workspace server",
    "infra:up": "docker compose up -d --wait postgres redis",
    "infra:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:seed": "npm run db:seed --workspace server",
    "db:reset": "node scripts/reset-local-db.mts",
    "demo:fresh-seed": "node scripts/fresh-seed-demo.mts",
    "lint": "npm run lint:root && npm run lint --workspaces --if-present",
    "lint:root": "eslint \"eslint.config.mts\" \"playwright.config.ts\" \"prettier.config.mts\" \"scripts/**/*.mts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern --cache --cache-location node_modules/.cache/eslint/",
    "lint:ci": "npm run lint:root:ci && npm run lint:ci --workspaces --if-present",
    "lint:root:ci": "eslint \"eslint.config.mts\" \"playwright.config.ts\" \"prettier.config.mts\" \"scripts/**/*.mts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings=0 --no-warn-ignored",
    "lint:root:fix": "eslint \"eslint.config.mts\" \"playwright.config.ts\" \"prettier.config.mts\" \"scripts/**/*.mts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "npm run typecheck:root && npm run typecheck --workspaces --if-present",
    "typecheck:root": "tsc --noEmit -p tsconfig.json",
    "test:acceptance": "playwright test",
    "test": "npm run test:root && npm run test --workspaces --if-present",
    "test:root": "node --test --test-isolation=none scripts/*.test.mts",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run format:check && npm run lint:ci && npm run typecheck && npm test && npm run build",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace server",
    "test:e2e": "npm run test:e2e --workspace server",
    "test:gate2": "npm run test:gate2 --workspace server"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
