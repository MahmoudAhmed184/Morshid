{
  "name": "morshid",
  "private": true,
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "overrides": {
    "@nestjs/platform-express": {
      "multer": "2.2.0"
    },
    "@prisma/dev": {
      "@hono/node-server": "1.19.14"
    }
  },
  "scripts": {
    "dev": "concurrently --names client,server --prefix-colors cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run start:dev --workspace server",
    "infra:up": "docker compose up -d --wait postgres redis",
    "infra:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:seed": "npm run db:seed --workspace server",
    "db:reset": "node scripts/reset-local-db.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "lint:ci": "npm run lint:ci --workspaces --if-present",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run format:check && npm run lint:ci && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "prettier": "^3.9.4"
  }
}
